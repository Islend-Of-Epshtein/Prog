<Window x:Class="L3S4.MenuMain"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="АИС Отдел кадров" Height="450" Width="800"
        WindowStartupLocation="CenterScreen">
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1">
            <Menu x:Name="MainMenu" Background="Transparent"/>
        </Border>

        <Border Grid.Row="1" Margin="12" Background="White" BorderBrush="White" BorderThickness="1"
                CornerRadius="6" Padding="12">
            <TextBlock x:Name="HeaderText" Text="Выбери пункт меню" FontSize="18" FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Window>