<Window x:Class="L3S4.LogInFrame"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:L3S4"
        xmlns:system="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="Вход" Height="300" Width="490" ResizeMode="CanResizeWithGrip" Icon="/logo.png" >
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="7*"></RowDefinition>
            <RowDefinition Height="3*"></RowDefinition>
            <RowDefinition Height="6*"></RowDefinition>
            <RowDefinition Height="6*"></RowDefinition>
            <RowDefinition Height="3*"></RowDefinition>
            <RowDefinition Height="2"></RowDefinition>
            <RowDefinition Height="2*"></RowDefinition>
        </Grid.RowDefinitions>
        
        
        <Rectangle Grid.RowSpan="7" Fill="#B9D1EA"/>
        
        
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="10"></ColumnDefinition>
                <ColumnDefinition Width="70"></ColumnDefinition>
                <ColumnDefinition Width="*"></ColumnDefinition>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                </Grid.RowDefinitions>
                
                <Border Grid.Row="0" Margin="3,4,2,1" Background="#FFFACD">
                </Border>

                <Border Grid.Row="1" Margin="3,4,2,1" Background="#FFD700">
                </Border>
            </Grid>

            <Grid Grid.Column="1" Background="Transparent" Cursor="None">
                <Image Source="/KEY_transperent.png" Margin="-32,-32,-32,-35" 
                       IsEnabled="False" Cursor="None" Stretch="Uniform">
                </Image>
            </Grid>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Margin="3,4,6,1" Background="#FFFACD">
                    <TextBlock Text="АИС Отдел кадров" VerticalAlignment="Center"
                               HorizontalAlignment="Right" FontSize="16"
                               Margin="0,0,5,0"/>
                </Border>

                <Border Grid.Row="1" Margin="3,3,9,2" Background="#FFD700">
                    <TextBlock x:Name="VersionBlock" Text="{Binding Version}" 
                               VerticalAlignment="Center" HorizontalAlignment="Right" 
                               FontSize="16" Margin="0,0,5,0"/>
                </Border>
            </Grid>
        </Grid>
        <Border Grid.Row="1" Margin="3,3,2,1" Background="White">
            <TextBlock Text="Введите имя пользователя и пароль" FontSize="16" Margin="2,0,2,0" 
                        VerticalAlignment="Center" HorizontalAlignment="Right">
            </TextBlock>
        </Border>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Grid.Column="0" Text="Имя пользователя" VerticalAlignment="Center" 
                        HorizontalAlignment="Left" FontSize="16" Margin="8"/>

            <TextBox x:Name="FieldName" Margin="10,20,10,20" Grid.Column="1" Background="White" 
                     BorderBrush="Black" 
                     Text="V" HorizontalAlignment="Stretch" 
                 VerticalAlignment="Center" BorderThickness="1" TextChanged="FieldName_TextChanged" />
        </Grid>
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>
        
            <TextBlock  Grid.Column="0" Text="Пароль" VerticalAlignment="Center" 
                        HorizontalAlignment="Stretch" FontSize="16" Margin="8"/>

            <TextBox x:Name="FieldPaswword" Margin="10,20,10,20" Grid.Column="1" Background="White" 
                        BorderBrush="Black" Text="123" HorizontalAlignment="Stretch"
                        VerticalAlignment="Center" BorderThickness="1" TextChanged="FieldPaswword_TextChanged"/>
        </Grid>
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" x:Name="buttonEnter" Content="Вход" 
                    FontSize="15" Margin="20,0,120,5" Click="buttonEnter_Click" />
            <Button Grid.Column="1" x:Name="buttonCanel" Content="Отмена"  
                    FontSize="15" Margin="120,0,20,5" Click="buttonCanel_Click"/>
        </Grid>
        <Grid Grid.Row="5" Background="White"/>
        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Grid.Column="0">
                <TextBlock FontSize="16">Язык ввода</TextBlock>
                <TextBlock Margin="10,0,0,0" FontSize="16" Text="{Binding SelectLanguage}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Grid.Column="1">
                <TextBlock FontSize="16" >Клавиша CapsLook</TextBlock>
                <TextBlock Margin="10,0,0,0" FontSize="16" Text="{Binding CapsLookGet}"/>
            </StackPanel>

            <Border Grid.Column="2" Background="White"/>
        </Grid>
    </Grid>
</Window>
